{
  "name": "n8n-nodes-negativardevedores",
  "version": "0.1.0",
  "description": "Community node n8n para a API de Negativação da RedeCredAuto (negativardevedores.com.br). Requer contrato ativo com a RedeCredAuto.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "redecredauto",
    "negativacao",
    "negativardevedores",
    "pefin",
    "refin",
    "divida"
  ],
  "license": "MIT",
  "homepage": "https://github.com/rca-group/n8n-negativardevedores#readme",
  "author": {
    "name": "RCA Group",
    "email": "suporte@redecredauto.com.br"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rca-group/n8n-negativardevedores.git"
  },
  "engines": {
    "node": ">=18.10",
    "pnpm": ">=8.6"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && eslint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RedeCredAutoApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RedeCredAuto/RedeCredAuto.node.js",
      "dist/nodes/RedeCredAuto/RedeCredAutoTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "~8.32.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "n8n-workflow": "*",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
